#!/bin/bash
set -euo pipefail
IFS=$'\n\t'

GREEN="\033[1;32m"
YELLOW="\033[1;33m"
RED="\033[1;31m"
BLUE="\033[1;34m"
CYAN="\033[1;36m"
RESET="\033[0m"

SCRIPT_URL="https://raw.githubusercontent.com/johannlo2013/doofusdollars/refs/heads/main/doofus.py"
SCRIPT_FILE="$(mktemp /tmp/doofus.py)"

cleanup() {
    if [[ -f "$SCRIPT_FILE" ]]; then
        rm -f "$SCRIPT_FILE" 2>/dev/null
        printf "${YELLOW}🧹 cleaned up temporary file.${RESET}\n"
    fi
}
trap cleanup EXIT INT TERM

printf "${CYAN}💸 doofus bootstrapper initialized.\n${RESET}"

if ! command -v python3 &>/dev/null; then
    printf "${YELLOW}⚙️  python not found. installing...\n${RESET}"
    PY_PKG="/tmp/python.pkg"
    curl -L -o "$PY_PKG" "https://www.python.org/ftp/python/3.12.7/python-3.12.7-macos11.pkg" || {
        printf "${RED}❌ failed to download python installer\n${RESET}"
        exit 1
    }
    sudo installer -pkg "$PY_PKG" -target / || {
        printf "${RED}❌ python installation failed\n${RESET}"
        exit 1
    }
    rm -f "$PY_PKG"
    printf "${GREEN}✅ python installed successfully!\n${RESET}"
else
    printf "${GREEN}✅ python already installed.\n${RESET}"
fi

PY_VERSION=$(python3 -c 'import sys; print(".".join(map(str, sys.version_info[:2])))')
printf "${BLUE}🐍 python version detected: %s\n${RESET}" "$PY_VERSION"

MAJOR=${PY_VERSION%%.*}
MINOR=${PY_VERSION#*.}
MINOR=${MINOR%%.*}
if (( MAJOR < 3 || MINOR < 10 )); then
    printf "${YELLOW}🔔 warning: python %s is outdated (needs 3.10+ for selenium)\n${RESET}" "$PY_VERSION"
fi

CERT_INSTALLER=$(find /Applications -type f -name "Install Certificates.command" 2>/dev/null | head -n 1 || true)
if [[ -n "$CERT_INSTALLER" ]]; then
    printf "${BLUE}🔐 installing ssl root certificates...\n${RESET}"
    bash "$CERT_INSTALLER" || printf "${YELLOW}⚠️  certificate installation may have failed.\n${RESET}"
else
    printf "${CYAN}ℹ️  certificate installer not found; skipping.\n${RESET}"
fi

if ! python3 -m pip &>/dev/null; then
    printf "${BLUE}⚙️  setting up pip...\n${RESET}"
    python3 -m ensurepip --upgrade
fi

printf "${BLUE}📦 upgrading pip...\n${RESET}"
python3 -m pip install --upgrade pip >/dev/null || printf "${YELLOW}⚠️  pip upgrade skipped.\n${RESET}"

DEPS=(selenium pynput requests)
for dep in "${DEPS[@]}"; do
    if ! python3 -c "import $dep" &>/dev/null; then
        printf "${BLUE}⚙️  installing %s...\n${RESET}" "$dep"
        python3 -m pip install --user "$dep"
        printf "${GREEN}✅ %s installed successfully.\n${RESET}" "$dep"
    else
        printf "${GREEN}✔️  %s already available.\n${RESET}" "$dep"
    fi
done

printf "${CYAN}🌐 downloading fresh script from %s...\n${RESET}" "$SCRIPT_URL"
TIMESTAMP=$(date +%s)
if ! curl -fsSL -H "Cache-Control: no-cache" "${SCRIPT_URL}?t=${TIMESTAMP}" -o "$SCRIPT_FILE"; then
    printf "${RED}❌ failed to fetch script from %s\n${RESET}" "$SCRIPT_URL"
    exit 1
fi

if [[ ! -s "$SCRIPT_FILE" ]]; then
    printf "${RED}❌ downloaded file is empty\n${RESET}"
    exit 1
fi
printf "${GREEN}✅ script downloaded (%s bytes)\n${RESET}" "$(wc -c < "$SCRIPT_FILE")"

printf "${BLUE}🚀 launching doofusdollars...\n${RESET}"
python3 "$SCRIPT_FILE"

printf "${GREEN}🎉 credit completed successfully 💰\n${RESET}"
